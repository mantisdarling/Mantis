# ============================================================
# MANTIS v2 — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Core ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database (PostgreSQL via Supabase or Render) ──────────
DATABASE_URL="postgresql://user:password@host:5432/mantis"

# ── Redis (Upstash or Render Redis) ──────────────────────
REDIS_URL="redis://your-redis-host:6379"
REDIS_HOST="your-redis-host"

# ── Auth ──────────────────────────────────────────────────
# MUST be at least 32 characters long and random
JWT_SECRET="replace-this-with-a-very-long-random-string-min-32-chars"

# ── CORS ─────────────────────────────────────────────────
# Exact Vercel production URL — NO trailing slash
FRONTEND_URL="https://your-app.vercel.app"

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://your-api-url.onrender.com/auth/google/callback"

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── AWS S3 (File Uploads) ─────────────────────────────────
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="mantis-uploads"
AWS_REGION="us-east-1"

# ── AI ───────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── ML Microservice ───────────────────────────────────────
ML_SERVICE_URL="https://your-recommender-url.onrender.com"

# ── Email (SendGrid / SMTP) ───────────────────────────────
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="noreply@mantis.com"

# ============================================================
# FRONTEND (Vercel Environment Variables)
# ============================================================
NEXT_PUBLIC_API_URL="https://your-api.onrender.com"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
# Must match backend JWT_SECRET exactly:
JWT_SECRET="replace-this-with-a-very-long-random-string-min-32-chars"
