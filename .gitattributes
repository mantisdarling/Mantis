# Git line-ending normalization
* text=auto eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.py text eol=lf
*.prisma text eol=lf
*.proto text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.webm binary
